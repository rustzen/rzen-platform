# Vercel Postgres / Prisma
POSTGRES_PRISMA_URL="postgres://user:password@host:5432/database?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgres://user:password@host:5432/database"
# Vercel/Postgres compatibility value; current Prisma datasource reads the two
# variables above.
POSTGRES_URL="postgres://user:password@host:5432/database"

# Reserved for future callback/link generation; current source does not read it.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Dashboard auth
RUSTZEN_ADMIN_ALLOWED_HOSTS="admin.rustzen.com,rustzen-cloud.vercel.app"
RUSTZEN_ADMIN_USERNAME="admin"
RUSTZEN_ADMIN_PASSWORD="change-me"
RUSTZEN_ADMIN_SECRET="replace-with-long-random-string"
RUSTZEN_ADMIN_API_TOKEN="replace-with-long-random-admin-api-token"

# Legacy external license-server proxy. The default desktop client path is
# /api/licenses/* and does not require these values.
RUSTZEN_LICENSE_SERVER_URL="http://localhost:9812"
RUSTZEN_LICENSE_SERVER_TOKEN=""

# Local Prisma-backed license API token signing
LICENSE_JWT_SECRET="replace-with-long-random-license-token-secret"
LEMONSQUEEZY_WEBHOOK_SECRET=""

# Billing provider checkout and webhook integration. Test API keys use the Billing provider sandbox
# automatically; live keys use production.
CREEM_API_KEY=""
CREEM_WEBHOOK_SECRET=""
# Rustzen Clear Pro is a subscription-only Billing provider product: website-listed Pro price.
CREEM_RUSTZEN_CLEAR_PRODUCT_ID=""
CREEM_CHECKOUT_SUCCESS_URL="https://rustzen.com/checkout/success"

# Required Tauri updater manifest consumed by /api/updates/check.
# Point this at the Vercel Blob URL uploaded by the private rustzen-clear release workflow.
RUSTZEN_CLEAR_UPDATE_MANIFEST_URL="https://<blob-store>.public.blob.vercel-storage.com/rustzen-clear/releases/latest/zen-clear-updates.json"
